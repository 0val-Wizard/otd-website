# dependencies
node_modules/

# next.js
.next/
out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Installers are large (often >100MB; GitHub file limit). Copy OTD-0.1.0-arm64.dmg into
# public/downloads/ before `next build` so it ships with the static site, or use Git LFS.
# Alternatively set NEXT_PUBLIC_OTD_DMG_URL to an external HTTPS URL and omit the file here.
public/downloads/*.dmg

# env — never commit secrets (plain `.env` is common for local tooling)
.env
.env*.local
.env.production
